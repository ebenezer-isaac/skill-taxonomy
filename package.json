{
  "name": "skill-taxonomy",
  "version": "3.0.0",
  "description": "14,774 skills + Aho-Corasick automaton for O(n) multi-pattern matching. The largest open-source skill taxonomy with 175K+ aliases, hierarchical relationships, and built-in keyword extraction.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "tsx scripts/validate.ts",
    "fetch:api": "tsx scripts/fetch-via-api.ts",
    "import:linkedin": "tsx scripts/import-linkedin.ts",
    "import:lightcast": "tsx scripts/import-lightcast.ts",
    "import:verticals": "tsx scripts/import-verticals-enhanced.ts",
    "deduplicate": "tsx scripts/deduplicate-taxonomy.ts",
    "merge:all": "tsx scripts/merge-all.ts",
    "validate:llm": "tsx scripts/validate-with-llm.ts"
  },
  "keywords": [
    "ats",
    "resume",
    "skills",
    "taxonomy",
    "keyword-matching",
    "aho-corasick",
    "string-matching",
    "nlp",
    "hiring",
    "recruitment",
    "job-search",
    "skill-extraction",
    "text-analysis"
  ],
  "author": "Ebenezer Isaac",
  "license": "MIT",
  "homepage": "https://github.com/ebenezer-isaac/skill-taxonomy#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ebenezer-isaac/skill-taxonomy"
  },
  "bugs": {
    "url": "https://github.com/ebenezer-isaac/skill-taxonomy/issues"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
