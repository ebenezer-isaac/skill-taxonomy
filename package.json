{
  "name": "@llmconveyors/skill-taxonomy",
  "version": "2.0.0",
  "description": "Enterprise-grade skill taxonomy for ATS resume scoring — comprehensive ontology with hierarchical relationships, multi-source ingestion, and semantic deduplication",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "src/skill-taxonomy.json"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "tsx scripts/validate.ts",
    "fetch:api": "tsx scripts/fetch-via-api.ts",
    "import:linkedin": "tsx scripts/import-linkedin.ts",
    "import:lightcast": "tsx scripts/import-lightcast.ts",
    "import:verticals": "tsx scripts/import-verticals-enhanced.ts",
    "expand:aliases": "tsx scripts/expand-aliases.ts",
    "deduplicate": "tsx scripts/deduplicate-taxonomy.ts",
    "merge:all": "tsx scripts/merge-all.ts",
    "promote:misses": "tsx scripts/promote-misses.ts",
    "validate:llm": "tsx scripts/validate-with-llm.ts"
  },
  "keywords": [
    "ats",
    "resume",
    "skills",
    "taxonomy",
    "keyword-matching",
    "hiring",
    "recruitment"
  ],
  "author": "Ebenezer Isaac",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ebenezer-isaac/skill-taxonomy"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
